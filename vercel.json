{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/app/index.py"
    }
  ],
  "functions": {
    "app/index.py": {
      "maxDuration": 60,
      "excludeFiles": "{.github/**,Dockerfile,docker-compose.yml,prowlarr.yml,README.md}"
    }
  }
}
