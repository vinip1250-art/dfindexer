{
  "version": 2,
  "builds": [{ "src": "wsgi.py", "use": "@vercel/python" }],
  "routes": [{ "src": "/(.*)", "dest": "/wsgi.py" }],
  "env": {
    "RUN_ASYNC_TIMEOUT": "9",
    "ALL_SCRAPERS_MAX_CONCURRENT": "1",
    "HTTP_RETRY_MAX_ATTEMPTS": "1",
    "TRACKER_MAX_WORKERS": "5",
    "METADATA_MAX_CONCURRENT": "10",
    "SCRAPER_MAX_WORKERS": "4",
    "EMPTY_QUERY_MAX_LINKS": "4",
    "LOG_FORMAT": "json",
    "LOG_LEVEL": "2"
  }
}
